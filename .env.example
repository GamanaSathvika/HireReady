# Copy this file to `.env` in this folder (HireReady root) or to `brutal-feedback-api/.env`.
# Local `brutal-feedback-api/.env` overrides the root file for duplicate keys.
#
# Required for voice transcription (Whisper) and interview replies (Groq chat).
# Create a key: https://console.groq.com/keys
#
GROQ_API_KEY=

# Optional — frontend only (create `frontend/.env` if needed).
# Must match where `brutal-feedback-api` runs (iframe uses the same value via postMessage).
# VITE_API_BASE=http://localhost:3001
